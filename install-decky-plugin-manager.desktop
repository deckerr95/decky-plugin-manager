#!/usr/bin/env xdg-open
[Desktop Entry]
Name=Install Decky Plugin Manager
Exec=sh -c 'rm -f /tmp/dpm_install.sh; if curl -fsSL http://192.168.1.118:8000/install.sh -o /tmp/dpm_install.sh; then bash /tmp/dpm_install.sh; else echo "Install failed. Check connection or URL."; read; fi'
Icon=steamdeck-gaming-return
Terminal=true
Type=Application
StartupNotify=false
